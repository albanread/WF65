; n>$  ( n -- $s )
;     Format signed integer n as a decimal String.
proc(int_to_string_word)
    mov     rcx, UP
    mov     rdx, TOS
    win64_call(rt_int_to_string)
    cmp     rax, -1
    je      .err
    mov     TOS, rax
    next()
.err:
    mov     TOS, -2059
    call    throw_word
    next()
endp()


; $>n  ( $h -- n true | false )
;     Parse $h as a signed decimal integer.  On success pushes the
;     parsed value and -1 (true); on failure pushes only 0 (false).
;     Leading/trailing whitespace is trimmed before parsing.
proc(string_to_int_word)
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    ; Reserve a stack slot to hold the out value.  We'll use PAD
    ; for this — needs no allocation, the result is read out
    ; before we leave the proc.
    lea     r10, [UP + user_PAD]
    mov     rcx, r9
    mov     rdx, r10
    win64_call(rt_string_to_int)
    test    rax, rax
    jz      .parse_fail
    ; rax = -1 (success).  Push value then -1.
    ; Stack before: TOS = $h.  After: NOS = parsed_value, TOS = -1.
    mov     r10, [UP + user_PAD]                    ; parsed value
    mov     [DSP - cell], r10                       ; new NOS = parsed value
    mov     TOS, -1                                 ; TOS = true
    stk(0, 1)                                       ; one extra cell allocated
    next()
.parse_fail:
    ; Replace $h with 0 (false).
    mov     TOS, 0
    next()
.wrong:
    mov     TOS, -2060
    call    throw_word
    next()
.nil:
    mov     TOS, -2061
    call    throw_word
    next()
endp()


; empty$  ( -- $ )
;     Push a fresh zero-length String.  Mostly useful as the
;     starting value before a concatenation loop.  Uses
;     pushd_call_or to dodge the TOS/RAX clobber documented on the
;     macro.
proc(empty_string_word)
    mov     rcx, UP
    xor     rdx, rdx                                ; src=0 (ignored when len=0)
    xor     r8,  r8                                 ; len=0
    pushd_call_or(rt_string_from_bytes, .err)
    next()
.err:
    mov     TOS, -2059
    call    throw_word
    next()
endp()


; ── V2s stage D — extended operations ───────────────────────────────


; $contains?  ( $needle $h -- f )
;     True iff needle occurs anywhere in haystack (byte search).
proc(string_contains_word)
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     r11, [DSP]
    test    r11, r11
    jz      .nil
    mov     r10, r11
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     rcx, r11
    mov     rdx, r9
    win64_call(rt_string_contains)
    mov     TOS, rax
    stk(1, 0)
    next()
.wrong:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2060
    stk(0, 1)
    call    throw_word
    next()
.nil:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2061
    stk(0, 1)
    call    throw_word
    next()
endp()


; $rfind  ( $needle $h -- idx | -1 )
;     Index of LAST occurrence of needle in haystack.  Empty
;     needle returns haystack length.
proc(string_rfind_word)
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     r11, [DSP]
    test    r11, r11
    jz      .nil
    mov     r10, r11
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     rcx, r11
    mov     rdx, r9
    win64_call(rt_string_rfind)
    mov     TOS, rax
    stk(1, 0)
    next()
.wrong:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2060
    stk(0, 1)
    call    throw_word
    next()
.nil:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2061
    stk(0, 1)
    call    throw_word
    next()
endp()


; $repeat  ( $h n -- $s )
;     Fresh String containing $h concatenated n times.  n=0 yields
;     an empty String.  Throws -2058 if result would overflow
;     u32::MAX bytes.
proc(string_repeat_word)
    ; Stack: n in TOS, $h at [DSP].
    mov     r9, [DSP]
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    ; Build args: rcx=UP, rdx=$h, r8=n
    mov     rcx, UP
    mov     rdx, r9
    mov     r8,  TOS
    win64_call(rt_string_repeat)
    cmp     rax, -1
    je      .err
    ; ( $h n -- $s ): 2 in, 1 out.
    mov     TOS, rax
    stk(1, 0)
    next()
.err:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2058
    stk(0, 1)
    call    throw_word
    next()
.wrong:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2060
    stk(0, 1)
    call    throw_word
    next()
.nil:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2061
    stk(0, 1)
    call    throw_word
    next()
endp()


; $replace  ( $needle $repl $h -- $s )
;     Substitute every occurrence of needle in h with repl.
;     Empty needle returns h untouched (as a fresh copy).
proc(string_replace_word)
    ; Stack: $h in TOS, $repl at [DSP], $needle at [DSP+cell].
    ; Type-check all three.
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     r11, [DSP]
    test    r11, r11
    jz      .nil
    mov     r10, r11
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     r13, [DSP + cell]
    test    r13, r13
    jz      .nil
    mov     r10, r13
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    ; Call rt_string_replace(UP, needle, repl, haystack).
    mov     rcx, UP
    mov     rdx, r13                                ; $needle
    mov     r8,  r11                                ; $repl
    mov     r9,  TOS                                ; $h
    win64_call(rt_string_replace)
    cmp     rax, -1
    je      .err
    ; ( $needle $repl $h -- $s ): 3 in, 1 out.
    mov     TOS, rax
    stk(2, 0)
    next()
.err:
    ; Drop 3, push -2059.
    mov     TOS, [DSP + 2*cell]
    add     DSP, 3*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2059
    stk(0, 1)
    call    throw_word
    next()
.wrong:
    mov     TOS, [DSP + 2*cell]
    add     DSP, 3*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2060
    stk(0, 1)
    call    throw_word
    next()
.nil:
    mov     TOS, [DSP + 2*cell]
    add     DSP, 3*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2061
    stk(0, 1)
    call    throw_word
    next()
endp()


; $split  ( $sep $h -- $1 $2 ... $n n )
;     Split haystack on every occurrence of sep, push each piece
;     followed by the count.  Stack-shaped; appropriate for small
;     splits (cap 32 pieces).  Throws -2058 if the split would
;     exceed 32 parts, -2060 on wrong type, -2061 on nil, -2059
;     on heap exhaustion during piece allocation.
;
;     Pre-trigger an auto-step before calling so the loop's piece
;     allocations are unlikely to trip the fragmentation-retry
;     path (which could move earlier pieces — see the no-retry
;     note on rt_string_split_into).
proc(string_split_word)
    ; Stack: $h in TOS, $sep at [DSP].
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     r11, [DSP]
    test    r11, r11
    jz      .nil
    mov     r10, r11
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    ; Stash inputs (r13 = sep, r14 = haystack) and auto-step.
    mov     r13, r11
    mov     r14, r9
    mov     rcx, UP
    win64_call(rt_gc_auto_step)
    ; Call rt_string_split_into(UP, sep, haystack, PAD, 32).
    mov     rcx, UP
    mov     rdx, r13
    mov     r8,  r14
    lea     r9,  [UP + user_PAD]
    ; rt_string_split_into has 5 args.  Win64 passes 1-4 in
    ; rcx/rdx/r8/r9; arg 5 (max_parts) goes on the stack at
    ; [rsp+32] (above the 32-byte shadow).  win64_call macro only
    ; handles the 4-arg case, so do the alignment dance manually.
    mov     r12, rsp
    and     rsp, -16
    sub     rsp, 48                                 ; 32 shadow + 16 for arg5
    mov     qword ptr [rsp + 32], 32                ; arg5: max_parts
    call    rt_string_split_into
    mov     rsp, r12
    cmp     rax, -1
    je      .err
    ; rax = count of pieces emitted into PAD.
    ; Now push pieces onto data stack (in order), followed by count.
    ; Stack effect before:  TOS=$h, [DSP]=$sep.  We drop these two
    ; and then push N + 1 cells.
    ;
    ; Drop the inputs first.  After this DSP points at the original
    ; NNOS.
    add     DSP, cell                               ; drop one cell ($sep slot)
    ; TOS now temporarily invalid (we'll fix when committing).
    ; Stash count in r14.
    mov     r14, rax
    ; Loop: push each piece from PAD onto stack.
    xor     r13, r13                                ; index i = 0
    test    r14, r14
    jz      .push_count                             ; zero pieces — just push 0
    ; Push first piece into TOS (consumes the slot we just dropped).
    lea     r11, [UP + user_PAD]
    mov     TOS, [r11]
    inc     r13
    cmp     r13, r14
    jge     .push_count
.push_piece:
    ; Push subsequent pieces via standard pattern.
    mov     [DSP - cell], TOS
    mov     TOS, [r11 + r13 * cell]
    sub     DSP, cell
    inc     r13
    cmp     r13, r14
    jl      .push_piece
.push_count:
    ; Final: push the count.
    mov     [DSP - cell], TOS
    mov     TOS, r14
    sub     DSP, cell
    next()
.err:
    ; Drop ($sep $h), throw -2058 / -2059 (we use 2058 for both;
    ; the kernel can't easily distinguish here without an out-param).
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2058
    stk(0, 1)
    call    throw_word
    next()
.wrong:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2060
    stk(0, 1)
    call    throw_word
    next()
.nil:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2061
    stk(0, 1)
    call    throw_word
    next()
endp()


; ── V2s stage E — UTF-8, floats, char$, $words ──────────────────────


; $clen  ( $h -- chars )
;     Codepoint count.  O(n) scan of the UTF-8 payload.  Throws
;     -2063 on malformed UTF-8.  New throw code: -2063 = invalid
;     UTF-8 (see throw-codes section at top of file).
proc(string_clen_word)
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     rcx, r9
    win64_call(rt_string_clen)
    cmp     rax, -1
    je      .invalid
    mov     TOS, rax
    next()
.invalid:
    mov     TOS, -2063
    call    throw_word
    next()
.wrong:
    mov     TOS, -2060
    call    throw_word
    next()
.nil:
    mov     TOS, -2061
    call    throw_word
    next()
endp()


; $c@  ( $h char-idx -- codepoint )
;     Codepoint at character index.  Throws -2058 on out-of-bounds,
;     -2063 on malformed UTF-8.
proc(string_cat_word)
    ; Stack: char-idx in TOS, $h at [DSP].
    mov     r9, [DSP]
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     rcx, r9
    mov     rdx, TOS
    win64_call(rt_string_cat)
    cmp     rax, -1
    je      .bounds
    mov     TOS, rax
    stk(1, 0)
    next()
.bounds:
    ; Drop both, push -2058.  (Either OOB or malformed UTF-8 — the
    ; Rust side prints a more specific stderr message either way.)
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2058
    stk(0, 1)
    call    throw_word
    next()
.wrong:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2060
    stk(0, 1)
    call    throw_word
    next()
.nil:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2061
    stk(0, 1)
    call    throw_word
    next()
endp()


; $valid?  ( $h -- f )
;     True iff the payload bytes are well-formed UTF-8.  Cheap
;     predicate.
proc(string_valid_word)
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     rcx, r9
    win64_call(rt_string_valid)
    mov     TOS, rax
    next()
.wrong:
    mov     TOS, -2060
    call    throw_word
    next()
.nil:
    mov     TOS, -2061
    call    throw_word
    next()
endp()


; $validate  ( $h -- )
;     Throws -2063 if $h is not valid UTF-8, otherwise drops it.
;     Use to convert "untrusted bytes" into "guaranteed-valid
;     String" at a defensible boundary.
proc(string_validate_word)
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     rcx, r9
    win64_call(rt_string_valid)
    test    rax, rax
    jz      .invalid
    ; Drop $h.
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.invalid:
    mov     TOS, -2063
    call    throw_word
    next()
.wrong:
    mov     TOS, -2060
    call    throw_word
    next()
.nil:
    mov     TOS, -2061
    call    throw_word
    next()
endp()


; char$  ( codepoint -- $ )
;     Single-codepoint String.  ASCII codepoints (< 128) yield a
;     1-byte payload; larger codepoints up to 4 bytes per UTF-8.
;     Surrogates and codepoints > U+10FFFF throw -2063.
proc(char_to_string_word)
    mov     rcx, UP
    mov     rdx, TOS
    win64_call(rt_char_to_string)
    cmp     rax, -1
    je      .err
    mov     TOS, rax
    next()
.err:
    mov     TOS, -2063
    call    throw_word
    next()
endp()


; $upper  ( $h -- $s )
;     Unicode-aware uppercase.  Allocates a fresh String; byte
;     length may differ from input (e.g. ß → "SS").  Throws -2063
;     on malformed UTF-8.
proc(string_upper_word)
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     rcx, UP
    mov     rdx, r9
    win64_call(rt_string_upper)
    cmp     rax, -1
    je      .err
    mov     TOS, rax
    next()
.err:
    mov     TOS, -2063
    call    throw_word
    next()
.wrong:
    mov     TOS, -2060
    call    throw_word
    next()
.nil:
    mov     TOS, -2061
    call    throw_word
    next()
endp()


; $lower  ( $h -- $s )
proc(string_lower_word)
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    mov     rcx, UP
    mov     rdx, r9
    win64_call(rt_string_lower)
    cmp     rax, -1
    je      .err
    mov     TOS, rax
    next()
.err:
    mov     TOS, -2063
    call    throw_word
    next()
.wrong:
    mov     TOS, -2060
    call    throw_word
    next()
.nil:
    mov     TOS, -2061
    call    throw_word
    next()
endp()


; $>f  ( $h -- ) ( F: -- r true | false )
;     Parse $h as a decimal float.  On success pushes r onto the FP
;     stack and -1 onto the data stack.  On failure pushes only 0
;     onto the data stack and leaves the FP stack alone.  Trims
;     surrounding ASCII whitespace before parsing.
proc(string_to_float_word)
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    ; Use PAD as the out-bits scratch slot.
    lea     r10, [UP + user_PAD]
    mov     rcx, r9
    mov     rdx, r10
    win64_call(rt_string_to_float)
    test    rax, rax
    jz      .parse_fail
    ; Success: push the parsed f64 onto FP stack.
    mov     r11, [UP + user_PAD]                    ; raw bits
    mov     r10, [UP + user_FSP]
    sub     r10, cell
    mov     [UP + user_FSP], r10
    mov     [r10], r11
    ; Replace TOS with -1 (true).
    mov     TOS, -1
    next()
.parse_fail:
    mov     TOS, 0
    next()
.wrong:
    mov     TOS, -2060
    call    throw_word
    next()
.nil:
    mov     TOS, -2061
    call    throw_word
    next()
endp()


; f>$  ( -- $ ) ( F: r -- )
;     Format the top of the FP stack as a decimal String and push
;     onto the data stack.  Rust's f64-Display formatting:
;     shortest-round-trip output (e.g. 1.5, -3.14, 1e-9, inf, NaN).
proc(float_to_string_word)
    ; Pop f64 from FP stack into rdx.
    mov     r10, [UP + user_FSP]
    mov     rdx, [r10]
    add     r10, cell
    mov     [UP + user_FSP], r10
    mov     rcx, UP
    pushd_call_or(rt_float_to_string, .err)
    next()
.err:
    mov     TOS, -2059
    call    throw_word
    next()
endp()


; sb-append-f  ( sb -- ) ( F: r -- )
;     Append the formatted-decimal representation of r to the
;     builder.  Throws -2062 on capacity overflow.
proc(sb_append_float_word)
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 5                                  ; TAG_BUILDER
    jne     .wrong
    ; Pop f64 from FP stack.
    mov     r10, [UP + user_FSP]
    mov     rdx, [r10]
    add     r10, cell
    mov     [UP + user_FSP], r10
    mov     rcx, r9                                 ; builder
    win64_call(rt_sb_append_float)
    cmp     rax, -1
    je      .overflow
    ; Drop sb.
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.overflow:
    mov     TOS, -2062
    call    throw_word
    next()
.wrong:
    mov     TOS, -2060
    call    throw_word
    next()
.nil:
    mov     TOS, -2061
    call    throw_word
    next()
endp()


; $words  ( $h -- $1 $2 ... $n n )
;     Whitespace-tokenise: split on runs of ASCII whitespace,
;     drop empty pieces.  `s" foo   bar baz" $words` yields three
;     tokens.  Same 32-piece cap as $split.
proc(string_words_word)
    mov     r9, TOS
    test    r9, r9
    jz      .nil
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong
    ; Auto-step before the loop so piece allocations don't trip
    ; the fragmentation-retry path mid-tokenise (same hazard as
    ; $split).
    mov     r14, r9
    mov     rcx, UP
    win64_call(rt_gc_auto_step)
    ; Call rt_string_words_into(UP, haystack, PAD, 32).
    mov     rcx, UP
    mov     rdx, r14
    lea     r8,  [UP + user_PAD]
    mov     r9,  32
    win64_call(rt_string_words_into)
    cmp     rax, -1
    je      .err
    ; rax = piece count.  Mirror $split's push-loop.
    ; Stack effect: ( $h -- $1 $2 ... $n n ).  We consumed $h via
    ; rcx; the cached TOS is now stale (rax has the count).
    mov     r14, rax
    test    r14, r14
    jnz     .push_first
    ; Zero pieces: just replace TOS (was $h) with 0.
    mov     TOS, 0
    next()
.push_first:
    lea     r11, [UP + user_PAD]
    mov     TOS, [r11]
    xor     r13, r13
    inc     r13
    cmp     r13, r14
    jge     .push_count
.push_piece:
    mov     [DSP - cell], TOS
    mov     TOS, [r11 + r13 * cell]
    sub     DSP, cell
    inc     r13
    cmp     r13, r14
    jl      .push_piece
.push_count:
    mov     [DSP - cell], TOS
    mov     TOS, r14
    sub     DSP, cell
    next()
.err:
    mov     TOS, -2058
    call    throw_word
    next()
.wrong:
    mov     TOS, -2060
    call    throw_word
    next()
.nil:
    mov     TOS, -2061
    call    throw_word
    next()
endp()


; !$  ( $ handle -- )
;     Store a managed String pointer into a HEAPPTR slot.
;     Accepts nil ($ = 0) to allow clearing a slot; otherwise the
;     value must carry TAG_STRING.  Throws -2060 on a non-String
;     non-nil value.
;
;     This is `!heapptr` with an added type check — the broader
;     `!heapptr` accepts any tagged value, while `!$` enforces the
;     "String-typed slot" discipline that lets `@$` skip its own
;     type check at fetch time.  (We still type-check in @$ today
;     to defend against direct `!`s; that becomes redundant once
;     the convention is consistently used.)
proc(store_string_word)
    ; Stack: handle in TOS, $ at [DSP].
    mov     r9, [DSP]                               ; the $ value
    test    r9, r9
    jz      .store                                  ; nil is always OK
    mov     r10, r9
    and     r10, 7
    cmp     r10, 4
    jne     .wrong_type
.store:
    mov     qword ptr [TOS], r9                     ; *handle = $
    ; Drop both args.
    mov     TOS, [DSP + cell]
    stk(2, 0)
    next()

.wrong_type:
    mov     TOS, [DSP + cell]
    add     DSP, 2*cell
    mov     [DSP - cell], TOS
    mov     TOS, -2060
    stk(0, 1)
    call    throw_word
    next()
endp()
