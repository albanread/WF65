; ─────────────────────────────────────────────────────────────────────
; WF64 kernel — colon compiler.
;
; M4 lets users define new words at runtime via `:` … `;`. The compiled
; body is straight subroutine-threaded code in the dict heap:
;
;   - Each Forth word in the body becomes `call rel32` (5 bytes).
;   - Each literal number becomes `call do_lit` + `.quad N`   (13 bytes).
;   - `;` writes a single `ret` byte (0xC3).
;
; M3's VirtualAlloc2 placement guarantees every call between the kernel
; (.text) and the dict heap fits in the rel32 form, so we never need
; the 12-byte indirect path.
; ─────────────────────────────────────────────────────────────────────

; ─────────────────────────────────────────────────────────────────────
; REMINDER: RAX is the cached TOS (top of data stack).
; Any instruction that writes RAX (mov, xor, shl, add, lea, mul, div,
; rep movsb's implicit clobbers, etc.) destroys the user's TOS unless
; it has been spilled to [DSP - cell] first. When scratching, prefer
; RCX/RDX/R8-R11. Save the original TOS in another register at the
; function prologue if any later branch needs it back.
; ─────────────────────────────────────────────────────────────────────

; do_lit  ( -- n )   [runtime helper, never user-callable]
;     Compiled by `literal` as: call do_lit ; .quad N
;     The caller's return slot points at the 8-byte literal sitting
;     just past the `call` site. We load that quad, bump the return
;     past it, then ret as normal.
proc(do_lit)
    mov     r9,  [rsp]                       ; r9 = addr of inline data
    mov     r10, [r9]                        ; r10 = literal value
    add     qword ptr [rsp], 8               ; skip the 8 bytes on return
    mov     [DSP - cell], TOS                ; old TOS → new NOS slot
    mov     TOS, r10                         ; new TOS = literal
    stk(0, 1)                                ; sub rbp, 8
    next()
endp()

; do_flit  ( -- )   [runtime helper, never user-callable]
;     Compiled by `fliteral` as: call do_flit ; .quad bits
;     and pushes the IEEE-754 double onto the floating-point stack.
proc(do_flit)
    mov     r9, [rsp]
    mov     r10, [r9]
    add     qword ptr [rsp], 8
    mov     rcx, [UP + user_FSP]
    sub     rcx, cell
    mov     [rcx], r10
    mov     [UP + user_FSP], rcx
    next()
endp()

; do_slit  ( -- c-addr u )   [runtime helper, never user-callable]
;     Compiled by `sliteral` as: call do_slit ; .quad len ; <len bytes>
;     and pushes the inline string address and length.
proc(do_slit)
    mov     r9, [rsp]                       ; r9 = addr of inline len
    mov     r10, [r9]                       ; r10 = len
    lea     r11, [r9 + 8]                   ; r11 = string addr
    lea     rcx, [r11 + r10]                ; rcx = resume ip
    mov     [rsp], rcx
    mov     [DSP - cell], TOS               ; old TOS -> NNOS
    mov     [DSP - 2*cell], r11             ; c-addr -> NOS
    mov     TOS, r10                        ; len -> TOS
    stk(0, 2)
    next()
endp()

; do_clit  ( -- c-addr )   [runtime helper, never user-callable]
;     Compiled by `cliteral` as: call do_clit ; .byte len ; <len bytes>
;     and pushes the address of the inline counted string.
proc(do_clit)
    mov     r9, [rsp]                       ; r9 = addr of count byte
    movzx   r10, byte ptr [r9]              ; r10 = len
    lea     rcx, [r9 + r10 + 1]             ; rcx = resume ip
    mov     [rsp], rcx
    mov     [DSP - cell], TOS               ; old TOS -> NOS
    mov     TOS, r9                         ; counted string addr
    stk(0, 1)
    next()
endp()

; compile  ( xt -- )
;     WF32-style compile token for ordinary words: duplicate xt, map the
;     duplicate to its comp-field address, then dispatch that helper while
;     leaving the original xt on the stack for the helper to consume.
proc(compile_word)
    mov     [DSP - cell], TOS                ; duplicate xt
    stk(1, 2)
    call    to_comp                          ; ( xt xt -- xt a-comp )
    jmp     perform                          ; helper sees original xt on TOS
endp()

; xt-call,  ( xt -- )
;     Append a 5-byte `call rel32` pointing at xt to HERE.
;     Because the dict heap is within ±1.75 GB of every primitive
;     (M3's VirtualAlloc2 placement), the rel32 always fits.
proc(compile_comma)
    mov     r8, [UP + user_HERE]             ; r8 = HERE
    mov     byte ptr [r8], 0xE8              ; CALL opcode
    sub     TOS, r8
    sub     TOS, 5                           ; eax = xt - (HERE + 5)
    mov     dword ptr [r8 + 1], eax
    add     r8, 5
    mov     [UP + user_HERE], r8
    mov     [UP + user_TAIL_CALL], r8        ; remember the position right
                                              ; after the CALL for ; / EXIT
                                              ; tail-call optimisation
    ; Drop xt.
    mov     TOS, [DSP]
    stk(1, 0)                                ; add rbp, 8
    next()
endp()

; xt-call,-no-tco  ( xt -- )
;     Identical to compile, except it does NOT mark the emitted CALL as a
;     tail-call candidate.  Used as the dh_comp helper for primitives that
;     pop / juggle the return address themselves (rdrop, 2rdrop, n>r,
;     nr>) — patching those CALLs into JMPs would feed the callee a
;     stale rstack and crash.  Also clears any pending TAIL_CALL set by
;     an earlier compile, so the next ; / EXIT doesn't wrongly tail-call
;     a previously-emitted safe CALL across this unsafe one.
proc(compile_comma_no_tco)
    mov     r8, [UP + user_HERE]
    mov     byte ptr [r8], 0xE8
    sub     TOS, r8
    sub     TOS, 5
    mov     dword ptr [r8 + 1], eax
    add     r8, 5
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
endp()

; ── Literal folding ─────────────────────────────────────────────────
; Peephole optimisation for `<literal> <binop>` sequences.  When a
; foldable binary operator (+, -, *, and, or, xor) is compiled and the
; bytes immediately preceding HERE are a `call do_lit ; .quad N`
; literal emission, rewind HERE by 13 and emit an immediate-form
; instruction in place of the literal+CALL pair.  Saves 9..14 bytes
; per fold plus two CALL/RET round trips at runtime.
;
; Detection signature:
;   [HERE-13]     = 0xE8                       (CALL opcode)
;   [HERE-12..-9] = rel32 such that target == do_lit
;   [HERE-8..-1]  = literal value (8 bytes, must fit in signed imm32)
;
; If any check fails, the helper tail-jumps to compile_comma so the
; normal CALL emission still happens.  The fold also clears
; user_TAIL_CALL so the rewritten instruction is never mistaken for a
; tail-call candidate by ; / EXIT.

; (private) try_fold_literal  -- shared fold preamble.
;     On success: CF=0, rcx = literal value, r8 = HERE - 13 (rewound).
;     On failure: CF=1.  Caller tail-jumps to compile_comma.
;     Caller-saved usage: rcx, rdx, r8, r9.  Does NOT touch TOS (rax).
proc(try_fold_literal)
    mov     r8, [UP + user_HERE]
    cmp     byte ptr [r8 - 13], 0xE8         ; CALL opcode?
    jne     .no
    mov     edx, dword ptr [r8 - 12]         ; rel32 of the CALL
    movsxd  rdx, edx
    add     rdx, r8                          ; HERE + rel32
    sub     rdx, 8                           ; = (HERE-13)+5+rel32 = call target
    lea     r9, [rip + do_lit]
    cmp     rdx, r9
    jne     .no                              ; CALL doesn't target do_lit
    mov     rcx, [r8 - 8]                    ; literal value (full 64 bits)
    movsxd  rdx, ecx
    cmp     rdx, rcx
    jne     .no                              ; doesn't fit in signed imm32
    sub     r8, 13                           ; rewind HERE to start of literal
    clc
    ret
.no:
    stc
    ret
endp()

; fold-+,  ( xt -- )      ADD rax, imm   (acc form 48 05 imm32 = 6 B,
;                                          imm8 form 48 83 C0 ii = 4 B)
proc(fold_plus_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .imm32
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x83
    mov     byte ptr [r8 + 2], 0xC0          ; /0 = ADD
    mov     byte ptr [r8 + 3], cl
    add     r8, 4
    jmp     .commit
.imm32:
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x05          ; ADD rax, imm32 (accumulator)
    mov     dword ptr [r8 + 2], ecx
    add     r8, 6
.commit:
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

; fold--,  ( xt -- )      SUB rax, imm
proc(fold_minus_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .imm32
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x83
    mov     byte ptr [r8 + 2], 0xE8          ; /5 = SUB
    mov     byte ptr [r8 + 3], cl
    add     r8, 4
    jmp     .commit
.imm32:
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x2D          ; SUB rax, imm32 (accumulator)
    mov     dword ptr [r8 + 2], ecx
    add     r8, 6
.commit:
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

; fold-*,  ( xt -- )      IMUL rax, rax, imm  (no accumulator special form,
;                                                imm8 = 4 B, imm32 = 7 B)
proc(fold_times_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .imm32
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x6B          ; IMUL r64, r/m64, imm8
    mov     byte ptr [r8 + 2], 0xC0          ; ModR/M: rax,rax
    mov     byte ptr [r8 + 3], cl
    add     r8, 4
    jmp     .commit
.imm32:
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x69          ; IMUL r64, r/m64, imm32
    mov     byte ptr [r8 + 2], 0xC0
    mov     dword ptr [r8 + 3], ecx
    add     r8, 7
.commit:
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

; fold-and,  ( xt -- )    AND rax, imm
proc(fold_and_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .imm32
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x83
    mov     byte ptr [r8 + 2], 0xE0          ; /4 = AND
    mov     byte ptr [r8 + 3], cl
    add     r8, 4
    jmp     .commit
.imm32:
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x25          ; AND rax, imm32 (accumulator)
    mov     dword ptr [r8 + 2], ecx
    add     r8, 6
.commit:
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

; fold-or,  ( xt -- )     OR  rax, imm
proc(fold_or_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .imm32
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x83
    mov     byte ptr [r8 + 2], 0xC8          ; /1 = OR
    mov     byte ptr [r8 + 3], cl
    add     r8, 4
    jmp     .commit
.imm32:
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x0D          ; OR rax, imm32 (accumulator)
    mov     dword ptr [r8 + 2], ecx
    add     r8, 6
.commit:
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

; fold-xor,  ( xt -- )    XOR rax, imm
proc(fold_xor_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .imm32
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x83
    mov     byte ptr [r8 + 2], 0xF0          ; /6 = XOR
    mov     byte ptr [r8 + 3], cl
    add     r8, 4
    jmp     .commit
.imm32:
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x35          ; XOR rax, imm32 (accumulator)
    mov     dword ptr [r8 + 2], ecx
    add     r8, 6
.commit:
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

; ── More literal folds: shifts ──────────────────────────────────────
; Shifts only fold when the literal fits in a signed imm8 (the only
; encoding the SHL/SHR/SAR-by-immediate form supports).  Out-of-range
; literals fall back to a normal CALL.
;
;   op       | imm8 form
;   lshift   | 48 C1 E0 ii   SHL rax, imm8
;   rshift   | 48 C1 E8 ii   SHR rax, imm8
;   arshift  | 48 C1 F8 ii   SAR rax, imm8

proc(fold_lshift_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .no_fold                         ; shifts need imm8 fit
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0xC1
    mov     byte ptr [r8 + 2], 0xE0          ; /4 = SHL
    mov     byte ptr [r8 + 3], cl
    add     r8, 4
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

proc(fold_rshift_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .no_fold
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0xC1
    mov     byte ptr [r8 + 2], 0xE8          ; /5 = SHR
    mov     byte ptr [r8 + 3], cl
    add     r8, 4
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

proc(fold_arshift_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .no_fold
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0xC1
    mov     byte ptr [r8 + 2], 0xF8          ; /7 = SAR
    mov     byte ptr [r8 + 3], cl
    add     r8, 4
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

; ── More literal folds: equality ────────────────────────────────────
; `n = lit`  → sub rax, lit ; sub rax, 1     ; sbb rax, rax  (11/13 B)
;     CF=1 iff (rax - lit) == 0, i.e. rax == lit.
; `n <> lit` → sub rax, lit ; add rax, -1    ; sbb rax, rax  (11/13 B)
;     CF=1 iff (rax - lit) != 0, i.e. rax != lit.

proc(fold_equal_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .imm32
    ; imm8 form (11 B)
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x83
    mov     byte ptr [r8 + 2], 0xE8          ; SUB rax, imm8
    mov     byte ptr [r8 + 3], cl
    mov     byte ptr [r8 + 4], 0x48
    mov     byte ptr [r8 + 5], 0x83
    mov     byte ptr [r8 + 6], 0xE8          ; SUB rax, 1
    mov     byte ptr [r8 + 7], 0x01
    mov     byte ptr [r8 + 8], 0x48
    mov     byte ptr [r8 + 9], 0x19          ; SBB rax, rax
    mov     byte ptr [r8 + 10], 0xC0
    add     r8, 11
    jmp     .commit
.imm32:
    ; imm32 form (13 B)
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x2D          ; SUB rax, imm32 (accumulator)
    mov     dword ptr [r8 + 2], ecx
    mov     byte ptr [r8 + 6], 0x48
    mov     byte ptr [r8 + 7], 0x83
    mov     byte ptr [r8 + 8], 0xE8
    mov     byte ptr [r8 + 9], 0x01
    mov     byte ptr [r8 + 10], 0x48
    mov     byte ptr [r8 + 11], 0x19
    mov     byte ptr [r8 + 12], 0xC0
    add     r8, 13
.commit:
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

proc(fold_not_equal_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .imm32
    ; imm8 form (11 B)
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x83
    mov     byte ptr [r8 + 2], 0xE8          ; SUB rax, imm8
    mov     byte ptr [r8 + 3], cl
    mov     byte ptr [r8 + 4], 0x48
    mov     byte ptr [r8 + 5], 0x83
    mov     byte ptr [r8 + 6], 0xC0          ; ADD rax, imm8
    mov     byte ptr [r8 + 7], 0xFF          ;     (-1 as imm8)
    mov     byte ptr [r8 + 8], 0x48
    mov     byte ptr [r8 + 9], 0x19          ; SBB rax, rax
    mov     byte ptr [r8 + 10], 0xC0
    add     r8, 11
    jmp     .commit
.imm32:
    ; imm32 form (13 B)
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x2D          ; SUB rax, imm32 (accumulator)
    mov     dword ptr [r8 + 2], ecx
    mov     byte ptr [r8 + 6], 0x48
    mov     byte ptr [r8 + 7], 0x83
    mov     byte ptr [r8 + 8], 0xC0          ; ADD rax, -1
    mov     byte ptr [r8 + 9], 0xFF
    mov     byte ptr [r8 + 10], 0x48
    mov     byte ptr [r8 + 11], 0x19
    mov     byte ptr [r8 + 12], 0xC0
    add     r8, 13
.commit:
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

; ── More literal folds: unsigned-less (cheap cmp+sbb form) ──────────
; `n u< lit` → cmp rax, lit ; sbb rax, rax           (7/9 B)
;     CF=1 iff rax < lit unsigned.  sbb rax, rax materialises -1/0.
proc(fold_u_less_comp)
    call    try_fold_literal
    jc      .no_fold
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .imm32
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x83
    mov     byte ptr [r8 + 2], 0xF8          ; CMP rax, imm8
    mov     byte ptr [r8 + 3], cl
    mov     byte ptr [r8 + 4], 0x48
    mov     byte ptr [r8 + 5], 0x19          ; SBB rax, rax
    mov     byte ptr [r8 + 6], 0xC0
    add     r8, 7
    jmp     .commit
.imm32:
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x3D          ; CMP rax, imm32 (accumulator)
    mov     dword ptr [r8 + 2], ecx
    mov     byte ptr [r8 + 6], 0x48
    mov     byte ptr [r8 + 7], 0x19
    mov     byte ptr [r8 + 8], 0xC0
    add     r8, 9
.commit:
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

; ── More literal folds: general comparisons (cmp + setCC + movzx + neg) ─
; All seven of these share the same shape; only the setCC opcode byte
; differs.  Pattern:
;   cmp rax, lit       (4 B imm8 / 6 B imm32 accumulator)
;   setCC al           (3 B)
;   movzx eax, al      (3 B)
;   neg rax            (3 B)
; Totals: 13 B (imm8) or 15 B (imm32).
;
; setCC second-opcode byte cheat-sheet:
;   <  setl  0x9C   |   u>  seta  0x97
;   >  setg  0x9F   |   u<= setbe 0x96
;   <= setle 0x9E   |   u>= setae 0x93
;   >= setge 0x9D   |

@macro emit_cmp_setcc(setcc_byte)
    movsx   rdx, cl
    cmp     rdx, rcx
    jne     .imm32
    ; imm8 form (13 B)
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x83
    mov     byte ptr [r8 + 2], 0xF8          ; CMP rax, imm8
    mov     byte ptr [r8 + 3], cl
    mov     byte ptr [r8 + 4], 0x0F
    mov     byte ptr [r8 + 5], &setcc_byte   ; setCC al
    mov     byte ptr [r8 + 6], 0xC0
    mov     byte ptr [r8 + 7], 0x0F
    mov     byte ptr [r8 + 8], 0xB6          ; MOVZX eax, al
    mov     byte ptr [r8 + 9], 0xC0
    mov     byte ptr [r8 + 10], 0x48
    mov     byte ptr [r8 + 11], 0xF7
    mov     byte ptr [r8 + 12], 0xD8         ; NEG rax
    add     r8, 13
    jmp     .^commit
.imm32:
    ; imm32 form (15 B)
    mov     byte ptr [r8 + 0], 0x48
    mov     byte ptr [r8 + 1], 0x3D          ; CMP rax, imm32 (accumulator)
    mov     dword ptr [r8 + 2], ecx
    mov     byte ptr [r8 + 6], 0x0F
    mov     byte ptr [r8 + 7], &setcc_byte
    mov     byte ptr [r8 + 8], 0xC0
    mov     byte ptr [r8 + 9], 0x0F
    mov     byte ptr [r8 + 10], 0xB6
    mov     byte ptr [r8 + 11], 0xC0
    mov     byte ptr [r8 + 12], 0x48
    mov     byte ptr [r8 + 13], 0xF7
    mov     byte ptr [r8 + 14], 0xD8
    add     r8, 15
@endmacro

proc(fold_less_comp)
    call    try_fold_literal
    jc      .no_fold
    emit_cmp_setcc(0x9C)                     ; setl
.commit:
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

proc(fold_greater_comp)
    call    try_fold_literal
    jc      .no_fold
    emit_cmp_setcc(0x9F)                     ; setg
.commit:
    mov     [UP + user_HERE], r8
    mov     qword ptr [UP + user_TAIL_CALL], 0
    mov     TOS, [DSP]
    stk(1, 0)
    next()
.no_fold:
    jmp     compile_comma
endp()

